# ══════════════════════════════════════════════════════════════════════
# Holland2Stay 监控 — 系统配置
#
# 用户级配置（通知渠道、过滤条件、自动预订）统一在 Web 面板管理：
#   python web.py  →  浏览器打开 http://localhost:8088  →  「用户」页面
#
# 本文件只包含系统/全局设置，复制后按需修改即可。
# ══════════════════════════════════════════════════════════════════════

# ── Web 面板鉴权 ─────────────────────────────────────────────────────
# 留空（默认）则无需登录；设置后访问面板必须先登录
# ⚠️ 生产环境务必设置，否则面板无密码公开
WEB_USERNAME=
WEB_PASSWORD=

# 访客模式：true=登录页显示「访客模式」按钮（只读，无需密码），false=关闭
WEB_GUEST_MODE=true

# Flask session 密钥（首次启动自动生成并写入，也可手动指定）
# 固定值可在重启后保留已登录状态；留空则每次重启自动生成（会强制退出所有登录）
FLASK_SECRET=

# Session Cookie 安全设置
# HTTPS 部署（VPS + Caddy）时设为 true，本地开发保持 false
SESSION_COOKIE_SECURE=false
# Session 有效期（小时），默认 24 小时
SESSION_LIFETIME_HOURS=24

# ── 共享邮件服务（Resend） ───────────────────────────────────────────
# 启用后，用户在通知设置里选「使用 FlatRadar 邮件服务」即可只填收件邮箱，
# 不需要自己折腾 SMTP。三项都填齐才算开启；任意一项缺失视为关闭。
#
# 申请：https://resend.com → 免费档 3000/月 + 100/天
# 步骤：1) 注册 → 2) 在 dashboard 添加自己的域名 → 3) 按提示加 DNS 记录
#       4) 域名验证后即可拿 API key（以 re_ 开头）
#
# RESEND_FROM 必须是 Resend 已验证域名下的邮箱，否则 API 直接 403。
SHARED_EMAIL_ENABLED=true
RESEND_API_KEY=
RESEND_FROM=notify@example.com

# 公开的 Web 基址，用于在验证邮件里生成可点击的链接。
# 生产环境必填（否则邮件里的链接会用本地内网 host）。
# 例：PUBLIC_BASE_URL=https://flatradar.example.com
PUBLIC_BASE_URL=

# Resend 每日配额（防免费档 100/天被打爆）。默认对齐免费档的 80% buffer。
# 计数已落 SQLite (email_send_counters)，多 Gunicorn worker 共享，重启不丢。
RESEND_GLOBAL_DAILY_LIMIT=80
RESEND_PER_USER_DAILY_LIMIT=20

# ── DMARC 加固升级（非环境变量，纯文档） ────────────────────────────
# 域名初次跑通时 DMARC 策略是 p=none（仅监控）。
# 在域名稳定发邮件 2-4 周、确认 SPF/DKIM 通过率 ≥99% 后，建议升级：
#
#   1. p=quarantine — 冒充邮件进收件方垃圾箱（推荐第二阶段）
#       _dmarc TXT: v=DMARC1; p=quarantine; rua=mailto:dmarc@yourdomain
#   2. p=reject     — 冒充邮件直接退回（最严格，量大企业才需要）
#       _dmarc TXT: v=DMARC1; p=reject; rua=mailto:dmarc@yourdomain
#
# 升级前在 Resend dashboard 查 "Bounces / Complaints" 趋势，确认没有大量
# DKIM 失败（说明 DNS 没问题）。p=quarantine 永远不会让你的合法邮件被
# 完全退回，只是更严格地走 spam 路径，回滚到 p=none 也是 30s DNS 修改。

# ── 监控全局配置 ──────────────────────────────────────────────────────
# 普通轮询间隔（秒），默认 5 分钟；高峰期间隔在 Web 面板「设置」中调整
CHECK_INTERVAL=300

# 智能轮询高峰时段：
#   窗口① 早间 — 荷兰时间 8:30-10:00（新房源上架最集中时段）
#   窗口② 下午 — 荷兰时间 13:30-15:00（下午工作时间）
#   以下配置可在 Web 面板「设置 → 智能轮询」中直接修改，无需手动编辑
PEAK_INTERVAL=60
MIN_INTERVAL=15
PEAK_START=08:30
PEAK_END=10:00
PEAK_START_2=13:30
PEAK_END_2=15:00
PEAK_WEEKDAYS_ONLY=true
JITTER_RATIO=0.20

# 心跳通知间隔（分钟），默认 60（1 小时）；设为 0 禁用心跳
HEARTBEAT_INTERVAL_MINUTES=60

# 数据加密密钥（首次启动自动生成并写入，也可手动指定 32 字节 base64）
# ⚠️ 更换此密钥后所有已加密的敏感字段（用户密码、token）将无法解密
# DATA_ENCRYPTION_KEY=

# 目标城市，格式: "城市名,ID"，多个用 | 分隔
# 建议在 Web 面板「设置 → 目标城市」中选择，无需手动填写 ID
# 完整城市列表见 config.py → KNOWN_CITIES（26 个城市）
CITIES=Eindhoven,29

# 可用状态过滤（Available to book=179, Available in lottery=336）
AVAILABILITY_FILTERS=Available to book,179|Available in lottery,336

# 数据库文件路径
DB_PATH=data/listings.db

# 日志级别：DEBUG / INFO / WARNING
LOG_LEVEL=INFO

# 时区（IANA 标识符），用于图表日期分组和智能轮询时段判断
# Docker 容器默认 UTC，建议显式设为荷兰时区
TIMEZONE=Europe/Amsterdam

