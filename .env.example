# ── Web 面板鉴权 ─────────────────────────────────────────────────────
# 留空（默认）则无需登录；设置后访问面板必须先登录
WEB_USERNAME=admin
WEB_PASSWORD=123

# Flask session 密钥（首次启动会自动生成并写入，也可手动指定）
# 保持固定值可在重启后保留已登录状态；留空则每次重启自动生成
FLASK_SECRET=123

# ── 通知渠道 ─────────────────────────────────────────────────────────
# 启用哪些通知渠道（逗号分隔，可多选），留空则不发任何通知
# 可选值：imessage / telegram / email / whatsapp
NOTIFICATION_CHANNELS=imessage

# 是否开启通知（全局开关），设为 false 则静默运行，只写数据库不发消息
NOTIFICATIONS_ENABLED=true

# ── iMessage（macOS）────────────────────────────────────────────────
# 收件人：手机号（+31612345678）或 Apple ID 邮箱
# 要求：运行在 Mac 上，Messages.app 已登录 iMessage 账号
IMESSAGE_RECIPIENT=

# ── Telegram Bot ────────────────────────────────────────────────────
# 1. 向 @BotFather 发送 /newbot 创建机器人，获得 token
# 2. 向机器人发任意消息，再访问：
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    从响应中找到 "chat": {"id": ...} 即为 CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email（SMTP）────────────────────────────────────────────────────
# 常见配置：
# - Gmail     : EMAIL_SMTP_HOST=smtp.gmail.com,    EMAIL_SMTP_PORT=587, EMAIL_SMTP_SECURITY=starttls
# - Outlook   : EMAIL_SMTP_HOST=smtp.office365.com, EMAIL_SMTP_PORT=587, EMAIL_SMTP_SECURITY=starttls
# - QQ 邮箱    : EMAIL_SMTP_HOST=smtp.qq.com,       EMAIL_SMTP_PORT=465, EMAIL_SMTP_SECURITY=ssl
# 若 SMTP 服务器要求认证，请填写 EMAIL_USERNAME / EMAIL_PASSWORD（通常为授权码）
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURITY=starttls
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# ── WhatsApp（Twilio，付费服务）────────────────────────────────────
# 需要 Twilio 账号并开通 WhatsApp Sandbox（测试）或正式 WhatsApp Business
# https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=whatsapp:+14155238886
TWILIO_TO=whatsapp:+31612345678

# ── 基础配置 ─────────────────────────────────────────────────────────
# 轮询间隔（秒），默认 5 分钟
CHECK_INTERVAL=300

# 目标城市，格式: "城市名,ID"，多个用 | 分隔
# 建议通过 Web 面板（python web.py）的设置页选择，无需手动填写 ID
# 完整城市列表见 config.py → KNOWN_CITIES（26 个城市）
CITIES=Eindhoven,29

# 可用状态过滤（Available to book=179, Available in lottery=336）
AVAILABILITY_FILTERS=Available to book,179|Available in lottery,336

# 数据库文件路径
DB_PATH=data/listings.db

# 日志级别：DEBUG / INFO / WARNING
LOG_LEVEL=INFO

# 时区设置（IANA 标识符），用于图表日期分组和智能轮询时段
# Docker 容器通常为 UTC，需显式设为荷兰时区以确保天边界正确
TIMEZONE=Europe/Amsterdam

# ── 通知过滤条件（全部可选，留空表示不限制）─────────────────────────

# 最高月租（€），超过此值不发通知
MAX_RENT=

# 面积范围（m²）
MIN_AREA=
MAX_AREA=

# 最低楼层（0=地面层，1=一楼及以上）
MIN_FLOOR=

# 允许的入住人数类型，逗号分隔（留空=全部）
# 可选值：One / Two (only couples) / Family (parents with children)
ALLOWED_OCCUPANCY=

# 允许的户型，逗号分隔（留空=全部）
# 可选值：Studio / 1 / 2 / Loft (open bedroom area)
ALLOWED_TYPES=

# 允许的片区，逗号分隔（留空=全部）
# 可选值：Strijp / Centrum / Stratum / Bergen / Tongelre 等
ALLOWED_NEIGHBORHOODS=

# ── 自动预订（仅 Available to book）──────────────────────────────────

# 是否开启自动预订，默认关闭
AUTO_BOOK_ENABLED=false

# 试运行模式：true=只记录日志不实际操作，false=真正执行
# 首次使用建议先设为 true 验证流程
AUTO_BOOK_DRY_RUN=true

# Holland2Stay 账号
AUTO_BOOK_EMAIL=
AUTO_BOOK_PASSWORD=

# 自动预订专用过滤条件（独立于通知过滤，建议设置更严格的条件）
# 留空则与通知过滤相同
AUTO_BOOK_MAX_RENT=
AUTO_BOOK_MIN_AREA=
AUTO_BOOK_MAX_AREA=
AUTO_BOOK_MIN_FLOOR=
AUTO_BOOK_ALLOWED_OCCUPANCY=
AUTO_BOOK_ALLOWED_TYPES=
AUTO_BOOK_ALLOWED_NEIGHBORHOODS=
