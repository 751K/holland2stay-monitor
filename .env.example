# ══════════════════════════════════════════════════════════════════════
# Holland2Stay 监控 — 系统配置
#
# 用户级配置（通知渠道、过滤条件、自动预订）统一在 Web 面板管理：
#   python web.py  →  浏览器打开 http://localhost:8088  →  「用户」页面
#
# 本文件只包含系统/全局设置，复制后按需修改即可。
# ══════════════════════════════════════════════════════════════════════

# ── Web 面板鉴权 ─────────────────────────────────────────────────────
# 留空（默认）则无需登录；设置后访问面板必须先登录
# ⚠️ 生产环境务必设置，否则面板无密码公开
WEB_USERNAME=
WEB_PASSWORD=

# 访客模式：true=登录页显示「访客模式」按钮（只读，无需密码），false=关闭
WEB_GUEST_MODE=true

# Flask session 密钥（首次启动自动生成并写入，也可手动指定）
# 固定值可在重启后保留已登录状态；留空则每次重启自动生成（会强制退出所有登录）
FLASK_SECRET=

# Session Cookie 安全设置
# HTTPS 部署（VPS + Caddy）时设为 true，本地开发保持 false
SESSION_COOKIE_SECURE=false
# Session 有效期（小时），默认 24 小时
SESSION_LIFETIME_HOURS=24

# ── 监控全局配置 ──────────────────────────────────────────────────────
# 普通轮询间隔（秒），默认 5 分钟；高峰期间隔在 Web 面板「设置」中调整
CHECK_INTERVAL=300

# 智能轮询高峰时段：
#   窗口① 早间 — 荷兰时间 8:30-10:00（新房源上架最集中时段）
#   窗口② 下午 — 荷兰时间 13:30-15:00（下午工作时间）
#   以下配置可在 Web 面板「设置 → 智能轮询」中直接修改，无需手动编辑

# 心跳通知间隔（分钟），默认 60（1 小时）；设为 0 禁用心跳
HEARTBEAT_INTERVAL_MINUTES=60

# 目标城市，格式: "城市名,ID"，多个用 | 分隔
# 建议在 Web 面板「设置 → 目标城市」中选择，无需手动填写 ID
# 完整城市列表见 config.py → KNOWN_CITIES（26 个城市）
CITIES=Eindhoven,29

# 可用状态过滤（Available to book=179, Available in lottery=336）
AVAILABILITY_FILTERS=Available to book,179|Available in lottery,336

# 数据库文件路径
DB_PATH=data/listings.db

# 日志级别：DEBUG / INFO / WARNING
LOG_LEVEL=INFO

# 时区（IANA 标识符），用于图表日期分组和智能轮询时段判断
# Docker 容器默认 UTC，建议显式设为荷兰时区
TIMEZONE=Europe/Amsterdam

# ── 旧版迁移（v1 → v2，仅升级用户需要关注）───────────────────────────
# v2 起用户级配置（通知渠道/过滤/自动预订）已迁移至 data/users.json，
# 通过 Web 面板管理，不再从 .env 读取。
#
# 如果你从 v1 升级且 data/users.json 尚不存在，首次启动会自动把
# 原 .env 中的旧键（IMESSAGE_RECIPIENT / TELEGRAM_BOT_TOKEN 等）
# 迁移到 users.json，之后旧键不再生效。
#
# 新安装用户无需关心此注释。
