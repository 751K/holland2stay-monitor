your.domain.com {
    reverse_proxy h2s:8088

    # 安全响应头
    header {
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # 访问日志（挂载到宿主机 ./logs/caddy/access.log）
    log {
        output file /var/log/caddy/access.log {
            roll_size    10MiB
            roll_keep    7
            roll_keep_days 30
        }
        format json
    }
}
