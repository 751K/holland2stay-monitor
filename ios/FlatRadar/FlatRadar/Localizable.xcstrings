    "A one-time tip to support development.\nDoes not unlock any features.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A one-time tip to support development.\nDoes not unlock any features."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una contribución única para apoyar el desarrollo.\nNo desbloquea ninguna función."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een eenmalige donatie ter ondersteuning van de ontwikkeling.\nHiermee worden geen functies vrijgespeeld."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一次性打赏以支持开发。\n不会解锁任何功能。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一次性打賞以支持開發。\n不會解鎖任何功能。"
          }
        }
      }
    },
    "A real-time monitor for Holland2Stay availability.": {
