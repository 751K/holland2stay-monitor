    "Your account data, saved filters, alert history, and preferences will be permanently removed. This cannot be undone.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your account data, saved filters, alert history, and preferences will be permanently removed. This cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los datos de tu cuenta, los filtros guardados, el historial de alertas y tus preferencias se eliminarán de forma definitiva. Esta acción no se puede deshacer."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je accountgegevens, opgeslagen filters, meldingsgeschiedenis en voorkeuren worden definitief verwijderd. Dit kan niet ongedaan worden gemaakt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的账号数据、已保存的过滤条件、提醒历史和偏好设置将被永久删除。此操作不可撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的賬號數據、已保存的過濾條件、提醒歷史和偏好設置將被永久刪除。此操作不可撤銷。"
          }
        }
      }
    },
    "Your feedback has been submitted. I read every piece of feedback — it directly shapes what gets built next.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu comentario se ha enviado. Leo todos y cada uno de los comentarios, ya que influyen directamente en lo que se desarrollará a continuación."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je feedback is verzonden. Ik lees alle feedback — die is bepalend voor wat er vervolgens wordt ontwikkeld."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的反馈已提交。我会阅读每一条反馈——它们会直接影响接下来要开发的内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的反饋已提交。我會閱讀每一條反饋——它們會直接影響接下來要開發的內容。"
          }
        }
      }
    },
