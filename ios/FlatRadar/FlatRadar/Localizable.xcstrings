    "✅ Sent to %lld device%@. Check your lock screen.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "✅ Sent to %lld device%@. Check your lock screen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "✅ Enviado al dispositivo %lld%@. Comprueba la pantalla de bloqueo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "✅ Verzonden naar apparaat %lld%@. Kijk op je vergrendelingsscherm."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "✅ 已发送至 %lld 台设备%@。请查看锁屏。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "✅ 已發送至 %lld 臺設備%@。請查看鎖屏。"
          }
        }
      }
    },
