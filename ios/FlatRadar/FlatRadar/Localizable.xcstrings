    "Reload re-reads users.json and .env without restarting the process. Stop halts scraping; subsequent listings won't trigger push.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reload re-reads users.json and .env without restarting the process. Stop halts scraping; subsequent listings won't trigger push."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La opción «Reload» vuelve a leer los archivos users.json y .env sin reiniciar el proceso. La opción «Stop» detiene el rastreo; los listados posteriores no activarán la notificación push."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Met 'Reload' worden users.json en .env opnieuw geladen zonder het proces opnieuw te starten. Met 'Stop' wordt het scrapen gestopt; volgende vermeldingen leiden niet tot een pushmelding."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重新加载会重读 users.json 和 .env，无需重启进程。停止将中断抓取，后续房源不会触发推送。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "重新加載會重讀 users.json 和 .env，無需重啓進程。停止將中斷抓取，後續房源不會觸發推送。"
          }
        }
      }
    },
