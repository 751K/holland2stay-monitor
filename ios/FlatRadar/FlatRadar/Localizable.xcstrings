    "This will remove the user, their notification preferences, and revoke all their App sessions. This cannot be undone.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will remove the user, their notification preferences, and revoke all their App sessions. This cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará al usuario y sus preferencias de notificación, y anulará todas sus sesiones en la aplicación. Esta acción no se puede deshacer."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hierdoor worden de gebruiker en zijn of haar meldingsvoorkeuren verwijderd en worden alle appsessies beëindigd. Dit kan niet ongedaan worden gemaakt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将删除该用户、其通知偏好，并撤销其所有 App 会话。此操作不可撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將刪除該用戶、其通知偏好，並撤銷其所有 App 會話。此操作不可撤銷。"
          }
        }
      }
    },
