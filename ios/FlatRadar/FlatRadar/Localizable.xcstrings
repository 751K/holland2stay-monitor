          "stringUnit": {
            "state": "translated",
            "value": "Las cuentas de usuario reciben notificaciones push de anuncios que coinciden con sus criterios de búsqueda. La prueba de notificaciones push verifica esta sesión del dispositivo de principio a fin."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruikersaccounts ontvangen pushmeldingen voor advertenties die aan hun filtervoorwaarden voldoen. De testpush controleert deze apparaatsessie van begin tot eind."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用户账户会收到与其筛选条件匹配的房源推送通知。测试推送用于端到端验证当前设备会话。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用戶賬戶會收到與其篩選條件匹配的房源推送通知。測試推送用於端到端驗證當前設備會話。"
          }
        }
      }
    },
