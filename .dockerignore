# 运行时数据（通过 volume 挂载，不打包进镜像）
data/
logs/

# 构建产物
build/
dist/
*.spec

# 密钥（绝对不能打包进镜像）
.env
*.p8
*.p12

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# 版本控制
.git/
.gitignore

# 文档
docs/

# macOS 垃圾文件
.DS_Store

# 编辑器
.vscode/
.idea/
*.swp

# 工具脚本 + 打包（不需要进镜像）
tools/
packaging/
launcher.py

# iOS 客户端（不打包进服务端镜像）
ios/

# Claude 工具链
.claude/

# 测试
tests/

# 部署配置（宿主机用，不打包进镜像）
Caddyfile
docker-compose.yml
